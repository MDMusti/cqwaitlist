{
  "name": "cleanqueue",
  "version": "2.0.0",
  "private": true,
  "description": "CleanQueue — Enterprise Discord Platform (Waitlist + Bot)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node scripts/start-production.js",
    "start:api": "node server.js",
    "start:bot": "npm run start -w @cleanqueue/bot",
    "dev:bot": "npm run dev -w @cleanqueue/bot",
    "build": "npm run build -w @cleanqueue/shared && npm run build -w @cleanqueue/bot && node scripts/verify-bot-build.js",
    "build:netlify": "node scripts/generate-config.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
