// CleanQueue — Full schema (Phases 2–5)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Per-guild configuration (roles, channels, feature flags).
model GuildConfig {
  id        String   @id // Discord guild snowflake
  name      String?
  locale    String   @default("de")
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
  auditLogs AuditLog[]
  cases     Case[]
  tickets   Ticket[]

  @@map("guild_configs")
}

/// Discord user profile (cross-guild).
model User {
  id            String   @id // Discord user snowflake
  username      String?
  discriminator String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships Member[]
  auditLogs   AuditLog[] @relation("AuditActor")
  cases       Case[]     @relation("CaseTarget")

  @@map("users")
}

/// Guild membership link between User and GuildConfig.
model Member {
  id          String    @id @default(cuid())
  guildId     String
  userId      String
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  xp          Int       @default(0)
  level       Int       @default(1)
  strikes     Int       @default(0)
  streakDays  Int       @default(0)
  lastDaily   DateTime?
  lastXpAt    DateTime?

  guild GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("members")
}

/// Moderation case with strike tracking.
model Case {
  id          String    @id @default(cuid())
  guildId     String
  caseNumber  Int
  targetId    String
  moderatorId String?
  type        String // warn | mute | kick | ban | timeout | note
  reason      String?
  status      String    @default("open")
  duration    Int? // minutes for mute/timeout
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild  GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  target User        @relation("CaseTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([guildId, targetId])
  @@index([guildId, caseNumber])
  @@map("cases")
}

/// Audit log entry for logging module.
model AuditLog {
  id        String   @id @default(cuid())
  guildId   String
  actorId   String?
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  guild GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)
  actor User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([guildId, createdAt])
  @@map("audit_logs")
}

/// Support ticket channel record.
model Ticket {
  id         String    @id @default(cuid())
  guildId    String
  channelId  String    @unique
  userId     String
  department String
  status     String    @default("open")
  createdAt  DateTime  @default(now())
  closedAt   DateTime?

  guild GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, userId])
  @@map("tickets")
}
