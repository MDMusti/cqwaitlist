# Discord App (https://discord.com/developers/applications)
CLIENT_ID=
CLIENT_SECRET=
BOT_TOKEN=

# Discord Server
GUILD_ID=
NOTIFY_CHANNEL_ID=

# OAuth callback — muss exakt im Discord Developer Portal eingetragen sein
# Lokal (alles auf einem Server):  http://localhost:3000/callback
# Prod (getrenntes Backend):        https://dein-backend.onrender.com/callback
REDIRECT_URI=http://localhost:3000/callback

# Frontend-URL für Redirects nach OAuth (Prod: Custom Domain)
# Lokal: http://localhost:3000
# Prod:  https://cqwaitlist.com
FRONTEND_URL=http://localhost:3000

PORT=3000

# ── CleanQueue Phase 1+ Infrastructure ──
# Lokal mit docker compose up -d:
DATABASE_URL=postgresql://cleanqueue:cleanqueue@localhost:5432/cleanqueue
REDIS_URL=redis://localhost:6379

# Optional: Bot log level (debug | info | warn | error)
# LOG_LEVEL=info

# ── Nur Netlify (Build-Zeit, nicht Backend) ──
# PUBLIC_API_URL=https://dein-backend.onrender.com
